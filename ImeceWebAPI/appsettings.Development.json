{

  "Logging": {

    "LogLevel": {

      "Default": "Information",

      "Microsoft.AspNetCore": "Warning"

    }

  },

  "ExceptionHandling": {

    "IncludeExceptionDetailsInDevelopment": true,

    "IncludeTraceId": true,

    "LogValidationErrors": true

  },

  "DatabaseSchema": {

    "Enabled": true,

    "SeedDevelopmentData": true,

    "SeedRealisticContent": true,

    "ResetDatabase": true,

    "DevelopmentSeedVersion": "realistic-v2",

    "AllowedResetDatabaseNames": [ "SankoImece", "SankoImece_Test" ]

  },

  "FileStorage": {

    "MaxFileSizeBytes": 26214400

  },

  "Authentication": {

    "Mode": "LocalJwt",

    "Jwt": {

      "Issuer": "imece-webapi",

      "Audience": "imece-admin",

      "SigningKey": "DEV_ONLY_CHANGE_ME_IMECE_JWT_SIGNING_KEY_32CHARS_MIN",

      "AccessTokenMinutes": 480

    }

  },

  "Directory": {

    "Provider": "Sql"

  }

}
