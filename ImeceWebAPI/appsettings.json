{
    "ConnectionStrings": {
        "DefaultConnection": "Server=EYLUL\\SQLEXPRESS;Database=SankoImece;Trusted_Connection=True;TrustServerCertificate=True;"
    },

    "Database": {
        "Profile": "LocalIntegrated",
        "Server": "EYLUL",
        "Instance": "SQLEXPRESS",
        "DatabaseName": "SankoImece",
        "CreateIfMissing": true,
        "Encrypt": true,
        "TrustServerCertificate": true,
        "ConnectTimeoutSeconds": 30,
        "CommandTimeoutSeconds": 60
    },

    "DatabaseSchema": {
        "Enabled": false,
        "CreateDatabaseIfMissing": true,
        "AllowDestructiveChanges": false,
        "FailApplicationOnError": true,
        "CommandTimeoutSeconds": 120,
        "LockTimeoutSeconds": 60,
        "LogGeneratedSql": false,
        "SeedDevelopmentData": false
    },

    "//ContentIsolation": "Enforce=true YALNIZCA schema sync + backfill tamamlandıktan sonra açılmalıdır.",
    "ContentIsolation": {
        "Enforce": false
    },

    "//ContentScopeBackfill": "Güvenli varsayılan: kapalı + dry-run. Gerçek atama için DryRun=false ve DefaultCompanyCode verilmelidir.",
    "ContentScopeBackfill": {
        "Enabled": false,
        "DefaultCompanyCode": null,
        "FailOnUnassignedContent": true,
        "DryRun": true,
        "BatchSize": 500
    },

    "//Audit": "audit_log tablosu (schema sync) hazır olana kadar Enabled=false kalmalı; kritik olaylar yine de fail-closed'dur.",
    "Audit": {
        "Enabled": false,
        "ContentFailureMode": "FailOpen"
    },

    "ClientApplication": {
        "HeaderName": "X-Client-Application",
        "AllowedValues": [ "Web", "AdminPanel" ],
        "DefaultForRequests": "Web",
        "SystemValue": "System"
    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },

    "ExceptionHandling": {
        "IncludeExceptionDetailsInDevelopment": false,
        "IncludeTraceId": true,
        "LogValidationErrors": false
    },

    "Authentication": {
        "Mode": "Development"
    },

    "AllowedHosts": "*"
}